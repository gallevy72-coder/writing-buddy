# PostgreSQL connection string.
# Non-localhost hosts use SSL with rejectUnauthorized:false (see server/db.js).
DATABASE_URL=

# Secret used to sign/verify JWT auth tokens. Use a long random string.
JWT_SECRET=

# Required. Groq API key for the chat coach (llama-3.3-70b-versatile via Groq's OpenAI-compatible endpoint).
GROQ_API_KEY=

# Optional. HuggingFace inference token for FLUX.1-schnell illustrations.
# If unset, illustration requests fall back to a Groq-generated SVG.
# Note: FLUX.1-schnell is a gated model — accept the license at
# https://huggingface.co/black-forest-labs/FLUX.1-schnell with the same
# HF account that owns this token.
HF_API_KEY=

# Server port. Defaults to 3001 if unset.
PORT=
